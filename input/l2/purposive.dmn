<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" id="Definitions_0u0u9to_purposive" name="DRD-purposive" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.41.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <decision id="CC.A.eligibility_p" name="Eligible For Screening">
    <variable id="Variable_ScreeningDecision" name="ScreeningDecision" typeRef="Any" />
    <informationRequirement id="InformationRequirement_1vzu5r0">
      <requiredInput href="#InputData_02fg14t" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_0wkm6vz">
      <requiredInput href="#InputData_1sk33ns" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_0nkyla6">
      <requiredInput href="#InputData_0lguiok" />
    </informationRequirement>
    <authorityRequirement id="AuthorityRequirement_0ndkumy">
      <requiredAuthority href="#KnowledgeSource_1mbjkyq" />
    </authorityRequirement>
    <decisionTable id="DecisionTable_1h3ywkp" hitPolicy="UNIQUE">
      <input id="Input_1" label="Client Is Woman" biodi:width="159">
        <inputExpression id="InputExpression_1" typeRef="boolean">
          <text>ClientIsWoman</text>
        </inputExpression>
      </input>
      <input id="InputClause_02m5z7x" label="Age In Years">
        <inputExpression id="LiteralExpression_0gsgr7g" typeRef="number">
          <text>AgeInYears</text>
        </inputExpression>
      </input>
      <input id="InputClause_1q1mgjo" label="Living With HIV">
        <inputExpression id="LiteralExpression_0ibuwaj" typeRef="boolean">
          <text>LivingWithHIV</text>
        </inputExpression>
      </input>
      <output id="Output_1" label="Eligible for Screening" name="EligibleForScreening" typeRef="boolean" />
      <output id="OutputClause_0hq9puu" label="Screening Interval" name="ScreeningInterval" typeRef="string" />
      <rule id="DecisionRule_1yry35i">
        <description>Rec 1; GPS 7 prioritizes age 30–49. Interval resolved per cc-005 to 10 years (upper bound of Rec 8 range).</description>
        <inputEntry id="UnaryTests_06y1alu">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_17w14zn">
          <text>[30..49]</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1pia218">
          <text>false</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_0nqvuqs">
          <text>true</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0t64403">
          <text>"every 10 years"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_17r1uyq">
        <description>Below general population screening age</description>
        <inputEntry id="UnaryTests_1vhdlne">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0937r67">
          <text>&lt;30</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1obzyz6">
          <text>false</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1cm9kab">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_1b7yjfr">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1l3rrvn">
        <description>Above screening age range, HIV status known (both populations); null-HIV at age&gt;49 delegated to catch-all per cc-008</description>
        <inputEntry id="UnaryTests_1makmp4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_17fkd6l">
          <text>&gt;49</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0orbcmr">
          <text>not(null)</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1wiayor">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_1o2z5ok">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1925hkc">
        <description>Rec 21; WLHIV screening starts at age 25. Interval resolved per cc-005 to 5 years (upper bound of Rec 28 range).</description>
        <inputEntry id="UnaryTests_1vi22f4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0cuj145">
          <text>[25..49]</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1qm0gll">
          <text>true</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_0ssm3hb">
          <text>true</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0ajt3ys">
          <text>"every 5 years"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1gyepae">
        <description>Below WLHIV screening age</description>
        <inputEntry id="UnaryTests_0ry7mru">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1pbzs81">
          <text>&lt;25</text>
        </inputEntry>
        <inputEntry id="UnaryTests_01wl6gb">
          <text>true</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1gmysjc">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0k9ln5m">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_05t3z2o">
        <description>Per L1 terminology; see Interpretation Register</description>
        <inputEntry id="UnaryTests_1l1u1kn">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1s7r5km">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1k2yk07">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_16azkeb">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0t4p279">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_catchall_s_nullage">
        <description>Catch-all: woman with null age</description>
        <inputEntry id="UnaryTests_catchall_s_na1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_na2">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_na3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_catchall_s_na1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_catchall_s_na2">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_catchall_s_nullhiv">
        <description>Catch-all: woman with valid age but null HIV status</description>
        <inputEntry id="UnaryTests_catchall_s_nh1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_nh2">
          <text>not(null)</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_nh3">
          <text>null</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_catchall_s_nh1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_catchall_s_nh2">
          <text>null</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_catchall_s_nullwoman">
        <description>Catch-all: null Client Is Woman</description>
        <inputEntry id="UnaryTests_catchall_s_nw1">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_nw2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_catchall_s_nw3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_catchall_s_nw1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_catchall_s_nw2">
          <text>null</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <inputData id="InputData_02fg14t" name="Client Is Woman" />
  <inputData id="InputData_1sk33ns" name="Age In Years" />
  <inputData id="InputData_0lguiok" name="Living With HIV" />
  <knowledgeSource id="KnowledgeSource_1mbjkyq" name="WHO Cervical Cancer Screening Guidelines, July 2021" />
  <inputData id="InputData_1j6wfhx" name="Years Since Last Screen" />
  <inputData id="InputData_0sltltj" name="Prior Screen Result" />
  <decision id="CC.B.due_screening_p" name="Due for Screening">
    <informationRequirement id="InformationRequirement_1xfw83b">
      <requiredInput href="#InputData_1j6wfhx" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_156cfzw">
      <requiredInput href="#InputData_0sltltj" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_0qktxth">
      <requiredDecision href="#CC.A.eligibility_p" />
    </informationRequirement>
    <decisionTable id="DecisionTable_1jr7lzl" hitPolicy="UNIQUE">
      <input id="InputClause_0gwq2vr" label="Eligible For Screening">
        <inputExpression id="LiteralExpression_1rxhq8j" typeRef="boolean">
          <text>ScreeningDecision.EligibleForScreening</text>
        </inputExpression>
      </input>
      <input id="InputClause_0n2h6g6" label="Screening Interval">
        <inputExpression id="LiteralExpression_1x4oe4t" typeRef="string">
          <text>ScreeningDecision.ScreeningInterval</text>
        </inputExpression>
      </input>
      <input id="InputClause_043n6vv" label="Years Since Last Screen" biodi:width="192">
        <inputExpression id="LiteralExpression_00u5cs9" typeRef="number">
          <text>YearsSinceLastScreen</text>
        </inputExpression>
      </input>
      <input id="InputClause_0f57j2r" label="Prior Result">
        <inputExpression id="LiteralExpression_19kxe91" typeRef="string">
          <text>PriorResult</text>
        </inputExpression>
      </input>
      <output id="OutputClause_1ij1iar" label="Screening Status" name="ScreeningStatus" typeRef="string">
        <outputValues id="UnaryTests_1h5h3n3">
          <text>"never screened — screen now","not yet due","due","prior positive — enter triage pathway","not eligible"</text>
        </outputValues>
      </output>
      <rule id="DecisionRule_0hrknh0">
        <description>Never screened (YearsSinceLastScreen = null) — screen now regardless of interval or prior result</description>
        <inputEntry id="UnaryTests_04zppza">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0hmrzog">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_06qib6s">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_18olhja">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_02bjnk8">
          <text>"never screened — screen now"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1kowjor">
        <description>General population, negative prior, before rescreen target (cc-005: &lt;10 years since last screen)</description>
        <inputEntry id="UnaryTests_1aqowrs">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0jfvzb4">
          <text>"every 10 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_05y5kmc">
          <text>&lt;10</text>
        </inputEntry>
        <inputEntry id="UnaryTests_00moxyz">
          <text>"negative"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1027a4y">
          <text>"not yet due"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1623wc6">
        <description>General population, negative prior, at or past rescreen target (cc-005: &gt;=10 years; point-estimate two-bucket encoding — see cc-005 rationale)</description>
        <inputEntry id="UnaryTests_1tp0715">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1sjaw6k">
          <text>"every 10 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1wlnt85">
          <text>&gt;=10</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1hzecyw">
          <text>"negative"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1u6jvno">
          <text>"due"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_0v20651">
        <description>WLHIV, negative prior, before rescreen target (cc-005: &lt;5 years since last screen)</description>
        <inputEntry id="UnaryTests_1dcdrz3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_17zaw3k">
          <text>"every 5 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0mqdyzv">
          <text>&lt;5</text>
        </inputEntry>
        <inputEntry id="UnaryTests_15940j8">
          <text>"negative"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1q5o8iu">
          <text>"not yet due"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_0esotny">
        <description>WLHIV, negative prior, at or past rescreen target (cc-005: &gt;=5 years; point-estimate two-bucket encoding — see cc-005 rationale)</description>
        <inputEntry id="UnaryTests_0j86ajs">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_02732l5">
          <text>"every 5 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_17jdzki">
          <text>&gt;=5</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1ks34zt">
          <text>"negative"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_0xaboal">
          <text>"due"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1cti1wm">
        <description>Prior positive result — bypass interval check, enter triage pathway</description>
        <inputEntry id="UnaryTests_15md3ak">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0ltivu4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0z959n4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1ttecw5">
          <text>"positive"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_0sf9i0v">
          <text>"prior positive — enter triage pathway"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_1ldirb0">
        <description>Not eligible (upstream EligibleForScreening = false) — no screening indicated</description>
        <inputEntry id="UnaryTests_0ew65bw">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1ionudt">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1gwakwf">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0xnafoy">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_15icyrs">
          <text>"not eligible"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <inputData id="InputData_via" name="VIA Result" />
  <inputData id="InputData_suspicion" name="Suspicion of Cancer" />
  <inputData id="InputData_tztype" name="TZ Type" />
  <inputData id="InputData_histology" name="Histology Result" />
  <inputData id="InputData_pregnancy" name="Is Pregnant" />
  <decision id="CC.C.triage_p" name="Triage Decision">
    <variable id="Variable_triage" name="TriageDecision" typeRef="Any" />
    <informationRequirement id="InformationRequirement_triage_via">
      <requiredInput href="#InputData_via" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_triage_hiv">
      <requiredInput href="#InputData_0lguiok" />
    </informationRequirement>
    <decisionTable id="DecisionTable_triage" hitPolicy="UNIQUE">
      <input id="InputClause_triage_via" label="VIA Result">
        <inputExpression id="LiteralExpression_triage_via" typeRef="string">
          <text>VIAResult</text>
        </inputExpression>
      </input>
      <input id="InputClause_triage_hiv" label="Living With HIV">
        <inputExpression id="LiteralExpression_triage_hiv" typeRef="boolean">
          <text>LivingWithHIV</text>
        </inputExpression>
      </input>
      <output id="OutputClause_triage" label="Triage Status" name="TriageStatus" typeRef="string" />
      <rule id="DecisionRule_triage_pos">
        <description>VIA positive — proceed to treatment eligibility assessment</description>
        <inputEntry id="UnaryTests_triage_pos1">
          <text>"positive"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_triage_pos2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_triage_pos">
          <text>"VIA positive — eligible for treatment"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_triage_neg_gen">
        <description>VIA negative, general population — repeat HPV in 2 years</description>
        <inputEntry id="UnaryTests_triage_neg_gen1">
          <text>"negative"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_triage_neg_gen2">
          <text>false</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_triage_neg_gen">
          <text>"VIA negative — repeat HPV test in 2 years"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_triage_neg_hiv">
        <description>VIA negative, WLHIV — repeat HPV in 1 year</description>
        <inputEntry id="UnaryTests_triage_neg_hiv1">
          <text>"negative"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_triage_neg_hiv2">
          <text>true</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_triage_neg_hiv">
          <text>"VIA negative — repeat HPV test in 1 year"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_triage_cancer">
        <description>Suspected cancer — refer for evaluation and biopsy</description>
        <inputEntry id="UnaryTests_triage_cancer1">
          <text>"suspected cancer"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_triage_cancer2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_triage_cancer">
          <text>"suspected cancer — refer for evaluation and biopsy"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_triage_catchall">
        <description>Catch-all: unrecognized VIA result</description>
        <inputEntry id="UnaryTests_triage_ca1">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_triage_ca2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_triage_ca">
          <text>"unknown VIA result"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="CC.D.ablation_p" name="Ablation Eligibility">
    <variable id="Variable_ablation" name="AblationDecision" typeRef="Any" />
    <informationRequirement id="InformationRequirement_ablation_suspicion">
      <requiredInput href="#InputData_suspicion" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_ablation_tz">
      <requiredInput href="#InputData_tztype" />
    </informationRequirement>
    <decisionTable id="DecisionTable_ablation" hitPolicy="UNIQUE">
      <input id="InputClause_ablation_suspicion" label="Suspicion of Cancer">
        <inputExpression id="LiteralExpression_ablation_suspicion" typeRef="boolean">
          <text>SuspicionOfCancer</text>
        </inputExpression>
      </input>
      <input id="InputClause_ablation_tz" label="TZ Type">
        <inputExpression id="LiteralExpression_ablation_tz" typeRef="string">
          <text>TZType</text>
        </inputExpression>
      </input>
      <output id="OutputClause_ablation" label="Ablation Eligible" name="AblationEligible" typeRef="boolean" />
      <rule id="DecisionRule_ablation_cancer">
        <description>Suspected cancer — not eligible for ablation</description>
        <inputEntry id="UnaryTests_ablation_cancer1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_cancer2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_cancer">
          <text>false</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_ablation_tz1">
        <description>TZ Type 1 — eligible for ablation</description>
        <inputEntry id="UnaryTests_ablation_tz1_1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_tz1_2">
          <text>"Type 1"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_tz1">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_ablation_tz2">
        <description>TZ Type 2 — eligible for ablation</description>
        <inputEntry id="UnaryTests_ablation_tz2_1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_tz2_2">
          <text>"Type 2"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_tz2">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_ablation_tz3">
        <description>TZ Type 3 — not eligible for ablation, requires excision</description>
        <inputEntry id="UnaryTests_ablation_tz3_1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_tz3_2">
          <text>"Type 3"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_tz3">
          <text>false</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_ablation_ca_nullsusp">
        <description>Catch-all: null suspicion of cancer</description>
        <inputEntry id="UnaryTests_ablation_ca_ns1">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_ca_ns2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_ca_ns">
          <text>false</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_ablation_ca_nulltz">
        <description>Catch-all: null TZ type</description>
        <inputEntry id="UnaryTests_ablation_ca_nt1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_ablation_ca_nt2">
          <text>null</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_ablation_ca_nt">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="CC.D.treatment_p" name="Treatment Decision">
    <variable id="Variable_treatment" name="TreatmentDecision" typeRef="Any" />
    <informationRequirement id="InformationRequirement_treatment_triage">
      <requiredDecision href="#CC.C.triage_p" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_treatment_ablation">
      <requiredDecision href="#CC.D.ablation_p" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_treatment_pregnancy">
      <requiredInput href="#InputData_pregnancy" />
    </informationRequirement>
    <decisionTable id="DecisionTable_treatment" hitPolicy="FIRST">
      <input id="InputClause_treatment_triage" label="Triage Status">
        <inputExpression id="LiteralExpression_treatment_triage" typeRef="string">
          <text>TriageDecision</text>
        </inputExpression>
      </input>
      <input id="InputClause_treatment_ablation" label="Ablation Eligible">
        <inputExpression id="LiteralExpression_treatment_ablation" typeRef="boolean">
          <text>AblationDecision</text>
        </inputExpression>
      </input>
      <input id="InputClause_treatment_pregnancy" label="Is Pregnant">
        <inputExpression id="LiteralExpression_treatment_pregnancy" typeRef="boolean">
          <text>IsPregnant</text>
        </inputExpression>
      </input>
      <output id="OutputClause_treatment" label="Treatment Plan" name="TreatmentPlan" typeRef="string" />
      <rule id="DecisionRule_treatment_pregnancy_defer">
        <description>Pregnancy deferral per GPS 41 (cc-006): defer ablation or LLETZ until after pregnancy. Fires before ablate/lletz rules under FIRST hit policy.</description>
        <inputEntry id="UnaryTests_treatment_pd1">
          <text>"VIA positive — eligible for treatment"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_pd2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_pd3">
          <text>true</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_pd">
          <text>"defer treatment until after pregnancy"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_ablate">
        <description>VIA positive, eligible for ablation — ablative treatment (non-pregnant or pregnancy status unknown; null IsPregnant falls through to this rule per cc-006 implementation note)</description>
        <inputEntry id="UnaryTests_treatment_ablate1">
          <text>"VIA positive — eligible for treatment"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_ablate2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_ablate3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_ablate">
          <text>"ablative treatment"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_lletz">
        <description>VIA positive, not eligible for ablation — LLETZ (non-pregnant or pregnancy status unknown)</description>
        <inputEntry id="UnaryTests_treatment_lletz1">
          <text>"VIA positive — eligible for treatment"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_lletz2">
          <text>false</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_lletz3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_lletz">
          <text>"LLETZ"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_repeat_gen">
        <description>VIA negative, general population — no treatment, repeat HPV (pregnancy irrelevant; no procedure to defer)</description>
        <inputEntry id="UnaryTests_treatment_rg1">
          <text>"VIA negative — repeat HPV test in 2 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_rg2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_rg3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_rg">
          <text>"no treatment — repeat HPV in 2 years"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_repeat_hiv">
        <description>VIA negative, WLHIV — no treatment, repeat HPV (pregnancy irrelevant; no procedure to defer)</description>
        <inputEntry id="UnaryTests_treatment_rh1">
          <text>"VIA negative — repeat HPV test in 1 year"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_rh2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_rh3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_rh">
          <text>"no treatment — repeat HPV in 1 year"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_refer">
        <description>Suspected cancer — refer for evaluation (per cc-006: pregnancy does NOT defer cancer evaluation; urgency is clinically appropriate regardless of pregnancy status)</description>
        <inputEntry id="UnaryTests_treatment_refer1">
          <text>"suspected cancer — refer for evaluation and biopsy"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_refer2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_refer3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_refer">
          <text>"refer for evaluation, biopsy and further management"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_treatment_catchall">
        <description>Catch-all: unrecognized triage status</description>
        <inputEntry id="UnaryTests_treatment_ca1">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_ca2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="UnaryTests_treatment_ca3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_treatment_ca">
          <text>"unknown triage status"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="CC.E.followup_p" name="Follow-up Decision">
    <variable id="Variable_followup" name="FollowUpDecision" typeRef="Any" />
    <informationRequirement id="InformationRequirement_followup_treatment">
      <requiredDecision href="#CC.D.treatment_p" />
    </informationRequirement>
    <informationRequirement id="InformationRequirement_followup_histology">
      <requiredInput href="#InputData_histology" />
    </informationRequirement>
    <decisionTable id="DecisionTable_followup" hitPolicy="UNIQUE">
      <input id="InputClause_followup_treatment" label="Treatment Plan">
        <inputExpression id="LiteralExpression_followup_treatment" typeRef="string">
          <text>TreatmentDecision</text>
        </inputExpression>
      </input>
      <input id="InputClause_followup_histology" label="Histology Result">
        <inputExpression id="LiteralExpression_followup_histology" typeRef="string">
          <text>HistologyResult</text>
        </inputExpression>
      </input>
      <output id="OutputClause_followup" label="Follow-up Plan" name="FollowUpPlan" typeRef="string" />
      <rule id="DecisionRule_followup_ablation_cin">
        <description>Ablative treatment, histology CIN3 or less — follow-up after 1 year</description>
        <inputEntry id="UnaryTests_followup_ac1">
          <text>"ablative treatment"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_ac2">
          <text>"CIN3 or less"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_ac">
          <text>"post-treatment follow-up after 1 year"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_ablation_cancer">
        <description>Ablative treatment, histology shows cancer</description>
        <inputEntry id="UnaryTests_followup_acan1">
          <text>"ablative treatment"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_acan2">
          <text>"cancer"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_acan">
          <text>"cancer — further management"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_lletz_cin">
        <description>LLETZ, histology CIN3 or less — follow-up after 1 year</description>
        <inputEntry id="UnaryTests_followup_lc1">
          <text>"LLETZ"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_lc2">
          <text>"CIN3 or less"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_lc">
          <text>"post-treatment follow-up after 1 year"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_lletz_cancer">
        <description>LLETZ, histology shows cancer</description>
        <inputEntry id="UnaryTests_followup_lcan1">
          <text>"LLETZ"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_lcan2">
          <text>"cancer"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_lcan">
          <text>"cancer — further management"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_repeat_gen">
        <description>No treatment, repeat HPV in 2 years (general population)</description>
        <inputEntry id="UnaryTests_followup_rg1">
          <text>"no treatment — repeat HPV in 2 years"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_rg2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_rg">
          <text>"repeat HPV test after 2 years"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_repeat_hiv">
        <description>No treatment, repeat HPV in 1 year (WLHIV)</description>
        <inputEntry id="UnaryTests_followup_rh1">
          <text>"no treatment — repeat HPV in 1 year"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_rh2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_rh">
          <text>"repeat HPV test after 1 year"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_refer">
        <description>Referred for evaluation — follow management pathway</description>
        <inputEntry id="UnaryTests_followup_ref1">
          <text>"refer for evaluation, biopsy and further management"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_ref2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_ref">
          <text>"evaluation, biopsy and further management"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_followup_catchall">
        <description>Catch-all: unrecognized treatment plan</description>
        <inputEntry id="UnaryTests_followup_ca1">
          <text>null</text>
        </inputEntry>
        <inputEntry id="UnaryTests_followup_ca2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_followup_ca">
          <text>"unknown treatment plan"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
