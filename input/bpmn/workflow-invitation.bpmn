<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Invitation" targetNamespace="http://dhes.github.io/smart-dak-cervical-cancer/bpmn/invitation" exporter="Hand-authored for smart-dak-cervical-cancer" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_Invitation">
    <bpmn:participant id="Participant_Community" name="Community" processRef="Process_Community" />
    <bpmn:participant id="Participant_Client" name="Client" processRef="Process_Client" />
    <bpmn:messageFlow id="MessageFlow_InvitationDelivered" name="Invitation delivered" sourceRef="Task_IssueInvitation" targetRef="Participant_Client" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Community" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Community">
      <bpmn:lane id="Lane_CHW" name="Community health worker">
        <bpmn:flowNodeRef>StartEvent_InvitationCycle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InvitationType</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IdentifyOverdue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IssueInvitation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_InvitationComplete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_InvitationCycle" name="Invitation cycle begins">
      <bpmn:outgoing>Flow_StartToGateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_InvitationType" name="Routine or overdue?">
      <bpmn:incoming>Flow_StartToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_RoutinePath</bpmn:outgoing>
      <bpmn:outgoing>Flow_OverduePath</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_IdentifyOverdue" name="Identify overdue rescreen candidate">
      <bpmn:incoming>Flow_OverduePath</bpmn:incoming>
      <bpmn:outgoing>Flow_OverdueToIssue</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_IssueInvitation" name="Issue screening invitation">
      <bpmn:incoming>Flow_RoutinePath</bpmn:incoming>
      <bpmn:incoming>Flow_OverdueToIssue</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueToEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_InvitationComplete" name="Invitation complete">
      <bpmn:incoming>Flow_IssueToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_StartToGateway" sourceRef="StartEvent_InvitationCycle" targetRef="Gateway_InvitationType" />
    <bpmn:sequenceFlow id="Flow_RoutinePath" name="Routine" sourceRef="Gateway_InvitationType" targetRef="Task_IssueInvitation" />
    <bpmn:sequenceFlow id="Flow_OverduePath" name="Overdue" sourceRef="Gateway_InvitationType" targetRef="Task_IdentifyOverdue" />
    <bpmn:sequenceFlow id="Flow_OverdueToIssue" sourceRef="Task_IdentifyOverdue" targetRef="Task_IssueInvitation" />
    <bpmn:sequenceFlow id="Flow_IssueToEnd" sourceRef="Task_IssueInvitation" targetRef="EndEvent_InvitationComplete" />
  </bpmn:process>
  <bpmn:process id="Process_Client" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Client">
      <bpmn:lane id="Lane_TargetClient" name="Target client" />
    </bpmn:laneSet>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Invitation">
    <bpmndi:BPMNPlane id="BPMNPlane_Invitation" bpmnElement="Collaboration_Invitation">
      <bpmndi:BPMNShape id="Participant_Community_di" bpmnElement="Participant_Community" isHorizontal="true">
        <dc:Bounds x="160" y="120" width="800" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_CHW_di" bpmnElement="Lane_CHW" isHorizontal="true">
        <dc:Bounds x="190" y="120" width="770" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_InvitationCycle_di" bpmnElement="StartEvent_InvitationCycle">
        <dc:Bounds x="240" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="214" y="235" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InvitationType_di" bpmnElement="Gateway_InvitationType" isMarkerVisible="true">
        <dc:Bounds x="335" y="185" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="320" y="155" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifyOverdue_di" bpmnElement="Task_IdentifyOverdue">
        <dc:Bounds x="460" y="300" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IssueInvitation_di" bpmnElement="Task_IssueInvitation">
        <dc:Bounds x="670" y="180" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_InvitationComplete_di" bpmnElement="EndEvent_InvitationComplete">
        <dc:Bounds x="870" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="848" y="235" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_StartToGateway_di" bpmnElement="Flow_StartToGateway">
        <di:waypoint x="276" y="210" />
        <di:waypoint x="335" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RoutinePath_di" bpmnElement="Flow_RoutinePath">
        <di:waypoint x="385" y="210" />
        <di:waypoint x="670" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="490" y="192" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OverduePath_di" bpmnElement="Flow_OverduePath">
        <di:waypoint x="360" y="235" />
        <di:waypoint x="360" y="330" />
        <di:waypoint x="460" y="330" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="370" y="270" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_OverdueToIssue_di" bpmnElement="Flow_OverdueToIssue">
        <di:waypoint x="600" y="330" />
        <di:waypoint x="635" y="330" />
        <di:waypoint x="635" y="210" />
        <di:waypoint x="670" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_IssueToEnd_di" bpmnElement="Flow_IssueToEnd">
        <di:waypoint x="810" y="210" />
        <di:waypoint x="870" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_Client_di" bpmnElement="Participant_Client" isHorizontal="true">
        <dc:Bounds x="160" y="440" width="800" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TargetClient_di" bpmnElement="Lane_TargetClient" isHorizontal="true">
        <dc:Bounds x="190" y="440" width="770" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="MessageFlow_InvitationDelivered_di" bpmnElement="MessageFlow_InvitationDelivered">
        <di:waypoint x="740" y="240" />
        <di:waypoint x="740" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="744" y="302" width="45" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
