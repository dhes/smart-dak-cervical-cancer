<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Triage"
                  targetNamespace="http://dhes.github.io/smart-dak-cervical-cancer/bpmn/triage"
                  exporter="Hand-authored for smart-dak-cervical-cancer"
                  exporterVersion="1.0">

  <bpmn:collaboration id="Collaboration_Triage">
    <bpmn:participant id="Participant_FacilityTriage"
                      name="Facility"
                      processRef="Process_FacilityTriage"/>
    <bpmn:participant id="Participant_ClientTriage"
                      name="Client"
                      processRef="Process_ClientTriage"/>
    <bpmn:messageFlow id="MessageFlow_Recall"
                      name="Recall for triage"
                      sourceRef="Task_ScheduleTriage"
                      targetRef="Participant_ClientTriage"/>
  </bpmn:collaboration>

  <bpmn:process id="Process_FacilityTriage" isExecutable="false">
    <bpmn:laneSet id="LaneSet_FacilityTriage">
      <bpmn:lane id="Lane_NurseTriage" name="Nurse/midwife">
        <bpmn:flowNodeRef>StartEvent_HPVPositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ScheduleTriage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IntermediateCatch_ClientAttendsTriage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_CounsellingTriage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PerformVIA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecordTriageResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_VIAResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TriageNegative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TriagePositive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SuspectedCancer</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_HPVPositive" name="Prior HPV result positive">
      <bpmn:outgoing>Flow_T1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ScheduleTriage" name="Schedule triage encounter">
      <bpmn:incoming>Flow_T1</bpmn:incoming>
      <bpmn:outgoing>Flow_T2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:intermediateCatchEvent id="IntermediateCatch_ClientAttendsTriage"
                                 name="Client attends triage encounter">
      <bpmn:incoming>Flow_T2</bpmn:incoming>
      <bpmn:outgoing>Flow_T3</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>

    <bpmn:callActivity id="CallActivity_CounsellingTriage"
                       name="Counselling and informed consent"
                       calledElement="Process_CounsellingConsent">
      <bpmn:incoming>Flow_T3</bpmn:incoming>
      <bpmn:outgoing>Flow_T4</bpmn:outgoing>
    </bpmn:callActivity>

    <bpmn:task id="Task_PerformVIA" name="Perform VIA triage">
      <bpmn:incoming>Flow_T4</bpmn:incoming>
      <bpmn:outgoing>Flow_T5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RecordTriageResult" name="Record triage result">
      <bpmn:incoming>Flow_T5</bpmn:incoming>
      <bpmn:outgoing>Flow_T6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_VIAResult" name="VIA result?">
      <bpmn:incoming>Flow_T6</bpmn:incoming>
      <bpmn:outgoing>Flow_T_Negative</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_Positive</bpmn:outgoing>
      <bpmn:outgoing>Flow_T_Suspicious</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_TriageNegative" name="Triage-negative">
      <bpmn:incoming>Flow_T_Negative</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_TriagePositive" name="Triage-positive">
      <bpmn:incoming>Flow_T_Positive</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SuspectedCancer" name="Suspected invasive cancer">
      <bpmn:incoming>Flow_T_Suspicious</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_T1" sourceRef="StartEvent_HPVPositive" targetRef="Task_ScheduleTriage"/>
    <bpmn:sequenceFlow id="Flow_T2" sourceRef="Task_ScheduleTriage" targetRef="IntermediateCatch_ClientAttendsTriage"/>
    <bpmn:sequenceFlow id="Flow_T3" sourceRef="IntermediateCatch_ClientAttendsTriage" targetRef="CallActivity_CounsellingTriage"/>
    <bpmn:sequenceFlow id="Flow_T4" sourceRef="CallActivity_CounsellingTriage" targetRef="Task_PerformVIA"/>
    <bpmn:sequenceFlow id="Flow_T5" sourceRef="Task_PerformVIA" targetRef="Task_RecordTriageResult"/>
    <bpmn:sequenceFlow id="Flow_T6" sourceRef="Task_RecordTriageResult" targetRef="Gateway_VIAResult"/>
    <bpmn:sequenceFlow id="Flow_T_Negative" name="Negative" sourceRef="Gateway_VIAResult" targetRef="EndEvent_TriageNegative"/>
    <bpmn:sequenceFlow id="Flow_T_Positive" name="Positive" sourceRef="Gateway_VIAResult" targetRef="EndEvent_TriagePositive"/>
    <bpmn:sequenceFlow id="Flow_T_Suspicious" name="Suspicious" sourceRef="Gateway_VIAResult" targetRef="EndEvent_SuspectedCancer"/>
  </bpmn:process>

  <bpmn:process id="Process_ClientTriage" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ClientTriage">
      <bpmn:lane id="Lane_TargetClientTriage" name="Target client"/>
    </bpmn:laneSet>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Triage">
    <bpmndi:BPMNPlane id="BPMNPlane_Triage" bpmnElement="Collaboration_Triage">

      <bpmndi:BPMNShape id="Participant_FacilityTriage_di" bpmnElement="Participant_FacilityTriage" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1220" height="320"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_NurseTriage_di" bpmnElement="Lane_NurseTriage" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1190" height="320"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_HPVPositive_di" bpmnElement="StartEvent_HPVPositive">
        <dc:Bounds x="240" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="218" y="255" width="80" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ScheduleTriage_di" bpmnElement="Task_ScheduleTriage">
        <dc:Bounds x="320" y="190" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IntermediateCatch_ClientAttendsTriage_di" bpmnElement="IntermediateCatch_ClientAttendsTriage">
        <dc:Bounds x="510" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="485" y="255" width="90" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CallActivity_CounsellingTriage_di" bpmnElement="CallActivity_CounsellingTriage">
        <dc:Bounds x="590" y="190" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PerformVIA_di" bpmnElement="Task_PerformVIA">
        <dc:Bounds x="770" y="190" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordTriageResult_di" bpmnElement="Task_RecordTriageResult">
        <dc:Bounds x="950" y="190" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_VIAResult_di" bpmnElement="Gateway_VIAResult" isMarkerVisible="true">
        <dc:Bounds x="1140" y="205" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1130" y="170" width="70" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_TriageNegative_di" bpmnElement="EndEvent_TriageNegative">
        <dc:Bounds x="1260" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1240" y="82" width="80" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_TriagePositive_di" bpmnElement="EndEvent_TriagePositive">
        <dc:Bounds x="1260" y="212" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1240" y="255" width="80" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SuspectedCancer_di" bpmnElement="EndEvent_SuspectedCancer">
        <dc:Bounds x="1260" y="322" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1235" y="365" width="100" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_T1_di" bpmnElement="Flow_T1">
        <di:waypoint x="276" y="230"/>
        <di:waypoint x="320" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T2_di" bpmnElement="Flow_T2">
        <di:waypoint x="460" y="230"/>
        <di:waypoint x="510" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T3_di" bpmnElement="Flow_T3">
        <di:waypoint x="546" y="230"/>
        <di:waypoint x="590" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T4_di" bpmnElement="Flow_T4">
        <di:waypoint x="730" y="230"/>
        <di:waypoint x="770" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T5_di" bpmnElement="Flow_T5">
        <di:waypoint x="910" y="230"/>
        <di:waypoint x="950" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T6_di" bpmnElement="Flow_T6">
        <di:waypoint x="1090" y="230"/>
        <di:waypoint x="1140" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T_Negative_di" bpmnElement="Flow_T_Negative">
        <di:waypoint x="1165" y="205"/>
        <di:waypoint x="1165" y="130"/>
        <di:waypoint x="1260" y="130"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1175" y="155" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T_Positive_di" bpmnElement="Flow_T_Positive">
        <di:waypoint x="1190" y="230"/>
        <di:waypoint x="1260" y="230"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1200" y="212" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_T_Suspicious_di" bpmnElement="Flow_T_Suspicious">
        <di:waypoint x="1165" y="255"/>
        <di:waypoint x="1165" y="340"/>
        <di:waypoint x="1260" y="340"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1175" y="295" width="70" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="Participant_ClientTriage_di" bpmnElement="Participant_ClientTriage" isHorizontal="true">
        <dc:Bounds x="160" y="440" width="1220" height="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TargetClientTriage_di" bpmnElement="Lane_TargetClientTriage" isHorizontal="true">
        <dc:Bounds x="190" y="440" width="1190" height="100"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="MessageFlow_Recall_di" bpmnElement="MessageFlow_Recall">
        <di:waypoint x="390" y="270"/>
        <di:waypoint x="390" y="440"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="355" y="350" width="110" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
